{
  "name": "@hairconnekt/backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "test:bookings": "node --require ts-node/register/transpile-only --test test/bookings.service.test.js",
    "test:integration": "bash run_tests.sh",
    "type-check": "tsc --noEmit",
    "typeorm:dev": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/data-source.ts",
    "typeorm": "node ./node_modules/typeorm/cli.js -d dist/data-source.js",
    "migration:generate": "npm run typeorm:dev -- migration:generate src/migrations/$npm_config_name -p",
    "migration:run:dev": "npm run typeorm:dev -- migration:run",
    "migration:revert:dev": "npm run typeorm:dev -- migration:revert",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "backfill:provider-geocodes": "ts-node -r tsconfig-paths/register src/scripts/backfill-provider-geocodes.ts",
    "normalize:provider-test-addresses": "ts-node -r tsconfig-paths/register src/scripts/normalize-provider-test-addresses.ts",
    "report:provider-geocodes": "ts-node -r tsconfig-paths/register src/scripts/report-provider-geocodes.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@getbrevo/brevo": "^6.0.2",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "disposable-email-domains": "^1.0.62",
    "expo-server-sdk": "^6.1.0",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.28",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/disposable-email-domains": "^1.0.6"
  }
}
