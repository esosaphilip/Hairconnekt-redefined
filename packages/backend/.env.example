NODE_ENV=production
PORT=3000

DATABASE_URL=postgres://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_SSL=true

JWT_ACCESS_SECRET=<set-me>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=<set-me>
JWT_REFRESH_EXPIRES=30d

BREVO_API_KEY=<set-me>
SMTP_FROM=noreply@hairconnekt.de
SMTP_FROM_NAME=HairConnekt

R2_ACCOUNT_ID=<set-me>
R2_ACCESS_KEY_ID=<set-me>
R2_SECRET_ACCESS_KEY=<set-me>
R2_BUCKET_NAME=<set-me>
R2_PUBLIC_URL=https://<public-bucket-base-url>
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

BCRYPT_ROUNDS=12
OTP_EXPIRES_MINUTES=10
OTP_DEV_MODE=false

CORS_ORIGIN=https://hairconnekt.de,https://admin.hairconnekt.de
