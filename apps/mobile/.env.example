# HairConnekt Mobile App — copy to .env and fill in real values
# Only EXPO_PUBLIC_ vars are bundled into the app binary — NEVER put secrets here.

EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_WS_URL=ws://localhost:3000
EXPO_PUBLIC_R2_BASE_URL=https://media.hairconnekt.de
EXPO_PUBLIC_GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
EXPO_PUBLIC_ENV=development
