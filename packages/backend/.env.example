# HairConnekt Backend — copy to .env and fill in real values
# See DOC 09 for full descriptions. NEVER commit this file with real values.

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/hairconnekt_dev
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=hairconnekt_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=CHANGE_ME
DATABASE_SSL=false

# JWT
JWT_ACCESS_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_CHAR_STRING
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Google OAuth
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Cloudflare R2
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET_NAME=hairconnekt-media
R2_PUBLIC_URL=https://media.hairconnekt.de
R2_ENDPOINT=https://CHANGE_ME.r2.cloudflarestorage.com

# Email (SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@hairconnekt.de
SMTP_FROM_NAME=HairConnekt

# Push Notifications
EXPO_ACCESS_TOKEN=CHANGE_ME

# Geocoding
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org/search
GEOCODING_USER_AGENT=HairConnekt/1.0 (support@hairconnekt.de)

# App Config
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:8081
BCRYPT_ROUNDS=12
OTP_EXPIRES_MINUTES=10
MAX_FILE_SIZE_MB=5

# Admin
ADMIN_EMAIL=admin@hairconnekt.de
ADMIN_PASSWORD=CHANGE_ME
