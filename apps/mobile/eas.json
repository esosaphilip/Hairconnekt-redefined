{
  "cli": {
    "version": ">= 9.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_ENV": "development",
        "EXPO_PUBLIC_API_URL": "https://hairconnekt-redefined.onrender.com/api/v1",
        "EXPO_PUBLIC_WS_URL": "wss://hairconnekt-redefined.onrender.com",
        "EXPO_PUBLIC_R2_BASE_URL": "https://media.hairconnekt.de"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_ENV": "preview",
        "EXPO_PUBLIC_API_URL": "https://hairconnekt-redefined.onrender.com/api/v1",
        "EXPO_PUBLIC_WS_URL": "wss://hairconnekt-redefined.onrender.com",
        "EXPO_PUBLIC_R2_BASE_URL": "https://media.hairconnekt.de"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://hairconnekt-redefined.onrender.com/api/v1",
        "EXPO_PUBLIC_WS_URL": "wss://hairconnekt-redefined.onrender.com",
        "EXPO_PUBLIC_R2_BASE_URL": "https://media.hairconnekt.de"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
