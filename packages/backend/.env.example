NODE_ENV=production
PORT=3000

DATABASE_URL=postgres://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_SSL=true

JWT_SECRET=<set-me>
JWT_EXPIRES_IN=1h
REFRESH_JWT_SECRET=<set-me>
REFRESH_JWT_EXPIRES_IN=30d

SENDGRID_API_KEY=<set-me>
SENDGRID_FROM_EMAIL=hello@hairconnekt.de

R2_ACCOUNT_ID=<set-me>
R2_ACCESS_KEY_ID=<set-me>
R2_SECRET_ACCESS_KEY=<set-me>
R2_BUCKET=<set-me>
R2_PUBLIC_BASE_URL=https://<public-bucket-base-url>

BCRYPT_ROUNDS=12
OTP_EXPIRES_MINUTES=10
OTP_DEV_MODE=false

CORS_ORIGIN=https://hairconnekt.de,https://admin.hairconnekt.de
