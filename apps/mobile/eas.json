{
  "cli": {
    "version": ">= 9.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "NODE_ENV": "production",
        "EXPO_PUBLIC_ENV": "development",
        "EXPO_PUBLIC_API_URL": "https://hairconnekt-api-staging.onrender.com/api/v1",
        "EXPO_PUBLIC_WS_URL": "wss://hairconnekt-api-staging.onrender.com",
        "EXPO_PUBLIC_R2_BASE_URL": "https://media.hairconnekt.de"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "NODE_ENV": "production",
        "EXPO_PUBLIC_ENV": "preview",
        "EXPO_PUBLIC_API_URL": "https://hairconnekt-api-staging.onrender.com/api/v1",
        "EXPO_PUBLIC_WS_URL": "wss://hairconnekt-api-staging.onrender.com",
        "EXPO_PUBLIC_R2_BASE_URL": "https://media.hairconnekt.de"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "staging": {
      "distribution": "internal",
      "channel": "staging",
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "NODE_ENV": "production",
        "EXPO_PUBLIC_ENV": "staging",
        "EXPO_PUBLIC_API_URL": "https://hairconnekt-api-staging.onrender.com/api/v1",
        "EXPO_PUBLIC_WS_URL": "wss://hairconnekt-api-staging.onrender.com",
        "EXPO_PUBLIC_R2_BASE_URL": "https://media.hairconnekt.de"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "NODE_ENV": "production",
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.hairconnekt.de/api/v1",
        "EXPO_PUBLIC_WS_URL": "wss://api.hairconnekt.de",
        "EXPO_PUBLIC_R2_BASE_URL": "https://media.hairconnekt.de"
      },
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production-internal": {
      "distribution": "internal",
      "channel": "production-internal",
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "NODE_ENV": "production",
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.hairconnekt.de/api/v1",
        "EXPO_PUBLIC_WS_URL": "wss://api.hairconnekt.de",
        "EXPO_PUBLIC_R2_BASE_URL": "https://media.hairconnekt.de"
      },
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6767045706"
      }
    }
  }
}
